# Root-level .gitignore for SmartPark monorepo

# Dependencies
node_modules/
**/node_modules/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Production builds
/build
**/build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Database files
*.db
*.sqlite
*.sqlite3

# Secrets
.secrets/
secrets.json

# Coverage
/coverage
**/coverage/
